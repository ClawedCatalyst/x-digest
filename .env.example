# ---------- shared ----------
APP_BASE_URL=
FRONTEND_BASE_URL=

# ---------- X / OAuth ----------
X_CLIENT_ID=YOUR_X_CLIENT_ID
# Optional for confidential clients; if you don't have it, leave blank and body will include client_id
X_CLIENT_SECRET=
X_REDIRECT_URI=

# OAuth scopes (space-separated)
X_SCOPES="tweet.read users.read like.read offline.access"

# ---------- backend ----------
PORT=8080
COOKIE_SECRET=change_me_to_a_long_random_string
ENCRYPTION_KEY_BASE64=CHANGE_ME_32_BYTES_BASE64   # 32 bytes base64 for AES-256-GCM

# ---------- postgres ----------
DATABASE_URL=